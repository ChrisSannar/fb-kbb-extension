{
  "manifest_version": 3,
  "name": "FB Marketplace → KBB",
  "version": "0.0.1",
  "description": "Toolbar popup that opens the matching Kelley Blue Book valuation page for a Facebook Marketplace car listing.",
  "permissions": ["activeTab", "declarativeContent"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check on KBB",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
